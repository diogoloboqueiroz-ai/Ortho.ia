# ── ORTHO.AI — Variáveis de Ambiente ──────────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores

# ── NEXTAUTH / AUTH.JS ────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET=GERE_COM_openssl_rand_base64_32

# ── GOOGLE OAUTH ──────────────────────────────────────────────────────────
# 1. Acesse: https://console.cloud.google.com
# 2. Crie um projeto → APIs & Services → Credentials → OAuth 2.0 Client
# 3. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#    e em produção: https://seudominio.com/api/auth/callback/google
AUTH_GOOGLE_ID=SEU_GOOGLE_CLIENT_ID
AUTH_GOOGLE_SECRET=SEU_GOOGLE_CLIENT_SECRET

# ── SUPABASE ──────────────────────────────────────────────────────────────
# 1. Acesse: https://supabase.com → New Project
# 2. Settings → API → copie os valores abaixo
NEXT_PUBLIC_SUPABASE_URL=https://SEUPROJETOID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY

# ── STRIPE ────────────────────────────────────────────────────────────────
# 1. Acesse: https://dashboard.stripe.com → Developers → API Keys
# 2. Para webhook: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY=sk_test_SUA_CHAVE_SECRETA
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_SUA_CHAVE_PUBLICA
STRIPE_WEBHOOK_SECRET=whsec_SEU_WEBHOOK_SECRET

# IDs dos preços no Stripe (crie em Products → Add product)
# Básico mensal R$97 → copie o Price ID
STRIPE_PRICE_BASICO_MENSAL=price_XXXXX
STRIPE_PRICE_BASICO_ANUAL=price_XXXXX
# Profissional mensal R$197
STRIPE_PRICE_PRO_MENSAL=price_XXXXX
STRIPE_PRICE_PRO_ANUAL=price_XXXXX
# Clínica mensal R$497
STRIPE_PRICE_CLINICA_MENSAL=price_XXXXX
STRIPE_PRICE_CLINICA_ANUAL=price_XXXXX

# ── ANTHROPIC (OrthoBrain Engine — análise profunda) ──────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE

# ── OPENAI (OrthoBrain Engine — respostas rápidas) ────────────────────────
# https://platform.openai.com → API Keys
# Usado para: quick consult, plantão mode, perguntas gerais (GPT-4o)
OPENAI_API_KEY=sk-SUA_CHAVE_OPENAI

# ── GEMINI (OrthoBrain Engine — visão e imagens) ──────────────────────────
# https://aistudio.google.com → Get API Key (gratuito para começar)
# Modelo usado: gemini-2.5-flash-preview-05-20
# Usado para: RX, RM, TC, US + pipeline duplo para laudos com imagem
# Gemini 2.5 Flash supera GPT-4o em visão médica a 8x menor custo
GEMINI_API_KEY=AIzaSy-SUA_CHAVE_GEMINI

# ── APP ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# E-mail do desenvolvedor — acesso gratuito permanente
DEVELOPER_EMAIL=diogo.lobo.queiroz@gmail.com
